rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // analysisJobs: ログイン済みユーザーのみ読み取り可能。書き込みはサーバー(Admin SDK)のみ。
    match /analysisJobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /comments/{bucketIndex} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // videoAnalysis: ログイン済みユーザーのみ読み取り可能。書き込みはサーバー(Admin SDK)のみ。
    match /videoAnalysis/{videoId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
